---
import Base from './Base.astro';
const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title} description={frontmatter.description || frontmatter.title}>
  <article style="padding-top: calc(5rem + 4rem); padding-bottom: 6rem;">
    <div class="container" style="max-width: 760px;">
      <div style="margin-bottom: 3rem;">
        <a href="/blog" class="back-link">← All writing</a>
      </div>
      <p class="section-label">{frontmatter.category || 'Essay'}</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 400; margin-bottom: 1rem; line-height: 1.1; letter-spacing: -0.03em;">
        {frontmatter.title}
      </h1>
      <p style="font-size: 0.8rem; color: var(--muted); letter-spacing: 0.08em; margin-bottom: 4rem; font-style: italic;">
        {new Date(frontmatter.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        {frontmatter.readTime && ` · ${frontmatter.readTime}`}
      </p>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

<style>
.back-link {
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  transition: color 0.2s;
}
.back-link:hover { color: var(--accent); }
</style>
