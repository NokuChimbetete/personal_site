---
import Base from '../layouts/Base.astro';

// ✏️ ADD YOUR REAL PROJECTS HERE
// thumbnail should be a path to an image in /public/images/
const featuredProjects = [
  {
    title: 'Puumba',
    category: 'Hackathon Winner',
    tech: 'TypeScript, LLM integration, Next.js',
    description: 'Duolingo for learning Vibe Coding. My friend and I won the 2025 Minna Hackathon (Tokyo) by creating a platform that gamifies learning to vibe code by pulling a code editor (Trae) into a cartoony UI that guides beginners through useful vibecoding tasks.',
    thumbnail: '/images/project-1.jpg',
    url: '#',
    linkText: 'View Repo',
  },
  {
    title: 'Minerva Vibe Check',
    category: 'Internal Tool',
    tech: 'JavaScript, Firebase',
    description: 'A real world sorting hat. I helped develop an internal tool that my university uses to sort incoming first years into "legacy" groups based on a hilarious personality quiz. My primary contribution was the algorithms that sort students, considering the global distribution between the 25 legacies and the answers to the 25 question survey.',
    thumbnail: '/images/project-2.png',
    url: '#',
    linkText: 'View Demo',
  },
  {
    title: 'ByteFriend',
    category: 'AI Agent',
    tech: 'Supabase, Node.js',
    description: 'Your first friend in Japan. My friend and I made an AI agent to help tourists and new residents in Japan navigate the immense bureaucratic procedures involved in creating their new lives.',
    thumbnail: '/images/project-3.png',
    url: '#',
    linkText: 'View Demo',
  },
];

// ✏️ PORTRAIT CAROUSEL — alternating photos & videos
// Sequence: photo-1 → hover → video-1 → photo-2 → hover → video-2 → … → last photo → wraps back
// Rule: always one more photo than videos (odd number of media elements)
// To add more: drop files in public/images/ and public/videos/ with the next number, then add paths here.
const portraitPhotos = [
  '/images/portrait-1.jpg',
  '/images/portrait-2.jpg',
  '/images/portrait-3.jpg',
  '/images/portrait-4.jpg',
];
const portraitVideos = [
  '/videos/portrait-1.mp4',
  '/videos/portrait-2.mp4',
  '/videos/portrait-3.mp4',
];

// ✏️ TYPEWRITER PHRASES — these cycle on the intro line
// Each phrase completes: "I'm Noku, and I ___"
const typedPhrases = [
  'write code.',
  'paint.',
  'tell stories.',
  'build things.',
  'make art.',
];
---

<Base>
  <!-- ── Hero ── -->
  <section class="hero container">

    <div class="hero-top-row">
      <!-- Portrait carousel: alternating photos & videos on hover -->
      <div class="hero-portrait-wrap fade-up" id="portrait-wrap">
        {/* Stack all photos — first one starts active */}
        {portraitPhotos.map((src, i) => (
          <img
            class={`portrait-media portrait-photo${i === 0 ? ' active' : ''}`}
            src={src}
            alt={`Noku Chimbetete — photo ${i + 1}`}
            draggable="false"
          />
        ))}

        {/* Stack all videos — none active initially, first one eager-preloaded */}
        {portraitVideos.map((src, i) => (
          <video
            class="portrait-media portrait-video"
            src={src}
            muted
            playsinline
            preload={i === 0 ? 'auto' : 'metadata'}
          />
        ))}

        <div class="hero-portrait-ring"></div>
      </div>

      <div class="hero-text-block">
        <h1 class="hero-name fade-up">
          Noku<br /><em>Chimbetete</em>
        </h1>

        <!-- Typewriter line -->
        <p class="hero-intro fade-up">
          <span class="static">Hey there friend, I </span><span class="typed" id="typewriter"></span>
        </p>

        <!-- ✏️ Write your own bio here -->
        <p class="hero-desc fade-up">
          Your bio goes here — a sentence or two that captures who you are
          across all three disciplines. Make it yours.
        </p>

        <div class="hero-links fade-up">
          <a href="/work" class="hero-link">View work</a>
          <a href="/blog" class="hero-link">Read writing</a>
          <a href="https://github.com/YOUR_HANDLE" target="_blank" rel="noopener" class="hero-link">GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Featured work ── -->
  <section class="section" id="projects" style="padding-block-start: clamp(3rem, 7vw, 5.5rem); padding-block-end: clamp(3rem, 7vw, 5.5rem);">
    <div class="container">
      <h2 class="section-title reveal" style="color: var(--accent); text-align: center;">What I've made</h2>

      <div class="cards-grid">
        {featuredProjects.map((p, i) => (
          <div class="flip-card reveal" style={`transition-delay: ${i * 0.04}s`}>
            <div class="flip-card-inner">
              <!-- Front: thumbnail -->
              <div class="flip-card-front">
                <img src={p.thumbnail} alt={p.title} loading="lazy" />
                <div class="flip-card-front-label">{p.title}</div>
                <span class="flip-card-hint">tap to flip</span>
              </div>
              <!-- Back: details -->
              <div class="flip-card-back">
                <div>
                  <p class="flip-card-back-category">{p.category}</p>
                  <h3 class="flip-card-back-title">{p.title}</h3>
                  <ul class="flip-card-back-tags">
                    {p.tech.split(', ').map((t) => (
                      <li class="flip-card-back-tag">{t}</li>
                    ))}
                  </ul>
                  <p class="flip-card-back-desc">{p.description}</p>
                </div>
                <a href={p.url} target="_blank" rel="noopener" class="flip-card-back-link">
                  {p.linkText || 'View project'} →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── Writing preview ── -->
  <section class="section" id="writing" style="padding-top: clamp(1.5rem, 3.5vw, 2.75rem)">
    <div class="container">
      <h2 class="section-title reveal" style="color: var(--accent); text-align: center;">Recent words</h2>

      <div class="blog-list">
        <!-- ✏️ These pull automatically once you add .md files to src/pages/blog/ -->
        <a href="/blog/first-post" class="blog-item">
          <span class="blog-item-title">Your first post title goes here</span>
          <span class="blog-item-meta">Jan 2025</span>
        </a>
        <a href="#" class="blog-item">
          <span class="blog-item-title">Another thing you wrote about</span>
          <span class="blog-item-meta">Feb 2025</span>
        </a>
      </div>

    </div>
  </section>
</Base>


<script define:vars={{ typedPhrases }}>
  // ── Typewriter effect ──
  const el = document.getElementById('typewriter');
  let phraseIndex = 0;
  let charIndex = 0;
  let deleting = false;
  const TYPE_SPEED = 80;
  const DELETE_SPEED = 45;
  const PAUSE_AFTER = 1800;
  const PAUSE_BEFORE = 300;

  function tick() {
    const phrase = typedPhrases[phraseIndex];
    if (!deleting) {
      el.textContent = phrase.slice(0, charIndex + 1);
      charIndex++;
      if (charIndex === phrase.length) {
        deleting = true;
        setTimeout(tick, PAUSE_AFTER);
        return;
      }
      setTimeout(tick, TYPE_SPEED);
    } else {
      el.textContent = phrase.slice(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        deleting = false;
        phraseIndex = (phraseIndex + 1) % typedPhrases.length;
        setTimeout(tick, PAUSE_BEFORE);
        return;
      }
      setTimeout(tick, DELETE_SPEED);
    }
  }
  setTimeout(tick, 900);

  // ── Portrait carousel state machine ──
  // Sequence: photo₀ → video₀ → photo₁ → video₁ → … → photoₙ → wrap
  // Even steps = photos, odd steps = videos.
  (() => {
    const wrap = document.getElementById('portrait-wrap');
    if (!wrap) return;

    const photos = Array.from(wrap.querySelectorAll('.portrait-photo'));
    const videos = Array.from(wrap.querySelectorAll('.portrait-video'));
    const numPhotos = photos.length;
    const numVideos = videos.length;
    const allMedia = [...photos, ...videos];

    let step = 0;          // current position in the sequence
    let hovering = false;  // is cursor currently over the portrait?

    // ── helpers ──
    const photoAt  = (s) => photos[s >> 1];
    const videoAt  = (s) => videos[(s - 1) >> 1];
    const isPhoto  = (s) => s % 2 === 0;
    const lastStep = 2 * numVideos;  // index of the last photo (no video after it)

    function show(step) {
      // Deactivate everything, then activate the one element for this step
      allMedia.forEach(el => el.classList.remove('active'));
      const target = isPhoto(step) ? photoAt(step) : videoAt(step);
      if (target) target.classList.add('active');
    }

    // Eagerly preload the next video so it's buffered before the user hovers
    function preloadNext(currentVideoIndex) {
      const next = currentVideoIndex + 1;
      if (next < numVideos && videos[next].preload !== 'auto') {
        videos[next].preload = 'auto';
        videos[next].load();   // start buffering now
      }
    }

    // ── transitions ──
    function enterHover() {
      if (!isPhoto(step)) return; // already on a video, ignore

      if (step < lastStep) {
        // Advance from photo → its paired video
        step++;
        show(step);
        const vid = videoAt(step);
        vid.currentTime = 0;
        vid.play().catch(() => {});
        preloadNext((step - 1) >> 1);
      } else {
        // Last photo reached — wrap back to photo₀
        step = 0;
        show(step);
        // If still hovering, start the first video after the crossfade settles
        setTimeout(() => {
          if (hovering && step === 0) enterHover();
        }, 500);
      }
    }

    function leaveHover() {
      if (isPhoto(step)) return; // already on a photo, nothing to do

      // Pause current video, advance to the next photo
      const vid = videoAt(step);
      vid.pause();
      vid.currentTime = 0;
      step++;
      if (step > lastStep) step = 0;
      show(step);
    }

    // ── event wiring ──
    wrap.addEventListener('mouseenter', () => { hovering = true;  enterHover(); });
    wrap.addEventListener('mouseleave', () => { hovering = false; leaveHover(); });

    // Mobile: tap toggles between photo → video and video → next photo
    wrap.addEventListener('touchstart', (e) => {
      e.preventDefault();
      if (isPhoto(step)) { hovering = true;  enterHover(); }
      else               { hovering = false; leaveHover(); }
    }, { passive: false });

    // When a video finishes naturally → advance to next photo, auto-chain if hovering
    videos.forEach((vid, i) => {
      vid.addEventListener('ended', () => {
        const expectedStep = 2 * i + 1;
        if (step !== expectedStep) return; // stale event

        step = expectedStep + 1;
        if (step > lastStep) step = 0;
        show(step);

        // If cursor is still over the portrait, auto-play the next video
        if (hovering) enterHover();
      });
    });

    // Preload all photos immediately (they're tiny) + start buffering video₀
    photos.forEach(img => { img.loading = 'eager'; });
    if (videos[0]) { videos[0].preload = 'auto'; videos[0].load(); }
  })();

  // ── Flip cards (click to flip) ──
  document.querySelectorAll('.flip-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      if (e.target.closest('.flip-card-back-link')) return;
      card.classList.toggle('flipped');
    });
  });

  // ── Scroll reveal ──
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.01, rootMargin: '0px 0px 60px 0px' });
  revealEls.forEach((el) => observer.observe(el));
</script>
